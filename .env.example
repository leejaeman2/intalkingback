# InTalking Backend 환경 변수 템플릿
# 사용법:
#   cp .env.example .env.development   (또는 .env.production)
#   값 채운 뒤 settings.py에서 python-dotenv로 로드

# development | production
DJANGO_ENV=development

# Django 보안
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
DEBUG=True
# 콤마 구분
ALLOWED_HOSTS=127.0.0.1,10.0.2.2,localhost

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# 데이터베이스
# 개발: django.db.backends.sqlite3 + DB_NAME=db.sqlite3 만 사용
# 운영: django.db.backends.postgresql + USER/PASSWORD/HOST/PORT 모두 필요
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# 국제화
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# Channels (WebSocket)
# 개발: channels.layers.InMemoryChannelLayer (REDIS_HOST 비워둠)
# 운영: channels_redis.core.RedisChannelLayer (REDIS_HOST/PORT 필수)
CHANNEL_BACKEND=channels.layers.InMemoryChannelLayer
REDIS_HOST=
REDIS_PORT=

# 정적 파일
STATIC_URL=static/
MEDIA_URL=/media/
